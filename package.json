{
  "name": "react-prep",
  "description": "ReactTeacher — local React interview prep: challenges, flashcards, and system design",
  "repository": {
    "type": "git",
    "url": "https://github.com/betexcr/react-teacher.git"
  },
  "homepage": "https://github.com/betexcr/react-teacher",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "generate": "node scripts/generate-challenges.mjs && node scripts/generate-flashcards.mjs && node scripts/copy-challenges-public.mjs && node scripts/generate-og-images.mjs",
    "dev": "npm run generate && vite",
    "build": "npm run generate && tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.16.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "sharp": "^0.34.5",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
